<div style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #1a1a1a;">
  <div style="padding: 32px 0; border-bottom: 2px solid #e5e7eb;">
    <h1 style="margin: 0; font-size: 24px; font-weight: 700;"><%= @company_name %></h1>
    <p style="margin: 4px 0 0; color: #6b7280; font-size: 14px;"><%= @company_address %></p>
  </div>

  <div style="padding: 24px 0;">
    <h2 style="margin: 0 0 8px; font-size: 20px;">Invoice <%= @invoice.invoice_number %></h2>
    <p style="margin: 0; color: #6b7280; font-size: 14px;">
      Due: <%= @invoice.due_date&.strftime("%B %d, %Y") || "Upon receipt" %>
    </p>
  </div>

  <div style="padding: 16px 0; border-top: 1px solid #e5e7eb;">
    <p style="margin: 0 0 4px; font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em;">Bill To</p>
    <p style="margin: 0; font-weight: 600;"><%= @invoice.client_name %></p>
    <% if @invoice.client_address.present? %>
      <p style="margin: 2px 0 0; color: #6b7280; font-size: 14px; white-space: pre-line;"><%= @invoice.client_address %></p>
    <% end %>
  </div>

  <% if @invoice.description.present? %>
    <div style="padding: 12px 0;">
      <p style="margin: 0; font-size: 14px;"><%= @invoice.description %></p>
    </div>
  <% end %>

  <table style="width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px;">
    <thead>
      <tr style="border-bottom: 2px solid #e5e7eb;">
        <th style="text-align: left; padding: 8px 0; color: #6b7280; font-weight: 600;">Description</th>
        <th style="text-align: right; padding: 8px 0; color: #6b7280; font-weight: 600; width: 60px;">Qty</th>
        <th style="text-align: right; padding: 8px 0; color: #6b7280; font-weight: 600; width: 100px;">Price</th>
        <th style="text-align: right; padding: 8px 0; color: #6b7280; font-weight: 600; width: 100px;">Amount</th>
      </tr>
    </thead>
    <tbody>
      <% @invoice.invoice_items.each do |item| %>
        <tr style="border-bottom: 1px solid #f3f4f6;">
          <td style="padding: 10px 0;"><%= item.description %></td>
          <td style="padding: 10px 0; text-align: right;"><%= item.quantity %></td>
          <td style="padding: 10px 0; text-align: right;">$<%= "%.2f" % (item.unit_price / 100.0) %></td>
          <td style="padding: 10px 0; text-align: right;">$<%= "%.2f" % (item.amount / 100.0) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <div style="margin: 16px 0; padding: 16px; background: #f9fafb; border-radius: 8px;">
    <table style="width: 100%; font-size: 14px;">
      <tr>
        <td style="padding: 4px 0; color: #6b7280;">Subtotal</td>
        <td style="padding: 4px 0; text-align: right;">$<%= "%.2f" % (@invoice.subtotal / 100.0) %></td>
      </tr>
      <% if @invoice.processing_fee_amount > 0 %>
        <tr>
          <td style="padding: 4px 0; color: #6b7280;">Processing Fee (<%= @invoice.processing_fee_percent %>%)</td>
          <td style="padding: 4px 0; text-align: right;">$<%= "%.2f" % (@invoice.processing_fee_amount / 100.0) %></td>
        </tr>
      <% end %>
      <% if @invoice.discount_amount > 0 %>
        <tr>
          <td style="padding: 4px 0; color: #6b7280;">Discount (<%= @invoice.discount_percent %>%)</td>
          <td style="padding: 4px 0; text-align: right; color: #16a34a;">-$<%= "%.2f" % (@invoice.discount_amount / 100.0) %></td>
        </tr>
      <% end %>
      <% if @invoice.tax_amount > 0 %>
        <tr>
          <td style="padding: 4px 0; color: #6b7280;">Tax (<%= @invoice.tax_percent %>%)</td>
          <td style="padding: 4px 0; text-align: right;">$<%= "%.2f" % (@invoice.tax_amount / 100.0) %></td>
        </tr>
      <% end %>
      <tr style="border-top: 2px solid #e5e7eb;">
        <td style="padding: 12px 0 4px; font-weight: 700; font-size: 16px;">Total Due</td>
        <td style="padding: 12px 0 4px; text-align: right; font-weight: 700; font-size: 16px;">$<%= "%.2f" % (@invoice.amount / 100.0) %></td>
      </tr>
    </table>
  </div>

  <% if @invoice.notes.present? %>
    <div style="padding: 12px 0; color: #6b7280; font-size: 13px;">
      <p style="margin: 0; font-weight: 600; color: #1a1a1a;">Notes</p>
      <p style="margin: 4px 0 0; white-space: pre-line;"><%= @invoice.notes %></p>
    </div>
  <% end %>

  <div style="padding: 24px 0; text-align: center;">
    <a href="<%= @payment_url %>" style="display: inline-block; padding: 14px 32px; background: #2563eb; color: #ffffff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 16px;">
      Pay Invoice
    </a>
  </div>

  <div style="padding: 16px 0; border-top: 1px solid #e5e7eb; text-align: center; color: #9ca3af; font-size: 12px;">
    <p style="margin: 0;"><%= @company_name %> &bull; <%= @company_phone %></p>
    <p style="margin: 4px 0 0;"><%= @company_email %></p>
  </div>
</div>
